# Reuse: existing Cognito pool + your existing OTEL collector + your existing
# network path. The gateway gets a fresh public ACM cert on the domain you own,
# but everything else plugs into what you already run.
#
# Usage:
#   cp config/managed-existingcognito-byotelemetry.env config/my.env
#   $EDITOR config/my.env
#   source config/my.env && ./deploy-all.sh

# Prereq: a PUBLIC Route53 hosted zone in YOUR OWN AWS account for
# PUBLIC_HOSTED_ZONE_ID below. ACM validates via DNS in that zone.

# --- REQUIRED ---------------------------------------------------------------
export DOMAIN_NAME="claude-gateway.example.com"
export PUBLIC_HOSTED_ZONE_ID="Zxxxxxxxxxxxxx"
export ALLOWED_DOMAINS="example.com"

# Existing Cognito pool id. cognito-existing-pool.yaml adds a NEW confidential
# app-client to it (does not modify the pool). Callback = https://$DOMAIN_NAME/oauth/callback.
export COGNITO_POOL_ID="us-east-1_xxxxxxxxx"

# YOUR existing OTEL collector. MUST be https:// and its cert must chain to a
# CA the gateway image trusts (public ACM works; corporate PKI needs its CA
# added to the gateway image — see gateway/README.md).
export COLLECTOR_ENDPOINT="https://your-otel.example.com/"

# Your existing network's client range that reaches the gateway VPC.
export CLIENT_CIDR="10.0.0.0/8"

# --- Toggles -----------------------------------------------------------------
export IDP_MODE="existing-cognito"
export ENABLE_COLLECTOR="false"                           # BYO — the URL above
export ENABLE_VPN="false"                                 # BYO network
export BUILD_IMAGE="true"
