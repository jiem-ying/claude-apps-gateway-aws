# Enterprise BYO: Okta / Entra / Google Workspace / Keycloak / any OIDC IdP,
# no bundled anything. The gateway is the only new AWS surface — everything
# else plugs into what your org already runs.
#
# Prereq: create a confidential OIDC web app in your IdP with redirect URI
#   https://<your DOMAIN_NAME>/oauth/callback
# and put its client secret in Secrets Manager. Set the four OIDC_* below.
#
# Usage:
#   cp config/byo-oidc-notelemetry.env config/my.env
#   $EDITOR config/my.env
#   source config/my.env && ./deploy-all.sh
# (or skip deploy-all.sh entirely and just run ./deploy.sh — it works standalone)

# Prereq: a PUBLIC Route53 hosted zone in YOUR OWN AWS account for
# PUBLIC_HOSTED_ZONE_ID below. ACM validates via DNS in that zone.

# --- REQUIRED ---------------------------------------------------------------
export DOMAIN_NAME="claude-gateway.example.com"
export PUBLIC_HOSTED_ZONE_ID="Zxxxxxxxxxxxxx"
export ALLOWED_DOMAINS="example.com"

# Your IdP (Okta shown). See docs/GUIDE.md "BYO integration" for other providers.
export OIDC_ISSUER="https://example.okta.com/oauth2/default"
export OIDC_CLIENT_ID="0oa1abcdEFGHIJKLMN0h8"
export OIDC_CLIENT_SECRET_ARN="arn:aws:secretsmanager:us-east-1:111122223333:secret:oidc-secret-abc123"
export GROUPS_CLAIM="groups"                              # Cognito=cognito:groups, Entra=roles

export CLIENT_CIDR="10.0.0.0/8"                           # your client range

# --- Toggles -----------------------------------------------------------------
export IDP_MODE="byo"                                     # skip Cognito stacks entirely
export COLLECTOR_ENDPOINT="off"                           # explicit: telemetry OFF
export ENABLE_COLLECTOR="false"
export ENABLE_VPN="false"
export BUILD_IMAGE="true"
