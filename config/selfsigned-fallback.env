# Fallback: no public domain — use a self-signed TLS cert. Peers/customers
# who can't (yet) set up a public Route53 zone can still stand this up, but
# the developer experience has friction: laptops need NODE_EXTRA_CA_CERTS
# pointing at gateway-ca.pem, Chrome/Safari must trust the CA, Firefox is a
# no-go (HSTS). Move to a managed-cert profile as soon as you have a domain.
#
# Usage:
#   cp config/selfsigned-fallback.env config/my.env
#   $EDITOR config/my.env
#   source config/my.env && ./deploy-all.sh

# --- REQUIRED ---------------------------------------------------------------
export ALLOWED_DOMAINS="example.com"
export ZONE="internal.example.com"                        # PRIVATE zone name to create
export GATEWAY_HOST="claude-gateway.${ZONE}"

# BYO OIDC — see byo-oidc-notelemetry.env for other paths.
export OIDC_ISSUER="https://example.okta.com/oauth2/default"
export OIDC_CLIENT_ID="0oa1abcdEFGHIJKLMN0h8"
export OIDC_CLIENT_SECRET_ARN="arn:aws:secretsmanager:us-east-1:111122223333:secret:oidc-secret-abc123"
export GROUPS_CLAIM="groups"

# Managed cert vars are UNSET — this triggers the self-signed path in deploy.sh.
unset DOMAIN_NAME PUBLIC_HOSTED_ZONE_ID

# --- Toggles -----------------------------------------------------------------
export IDP_MODE="byo"
export COLLECTOR_ENDPOINT="off"
export ENABLE_COLLECTOR="false"
export ENABLE_VPN="true"                                  # bundle the VPN too (peer likely needs it)
export BUILD_IMAGE="true"
