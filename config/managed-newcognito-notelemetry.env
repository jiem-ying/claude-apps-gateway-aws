# Lightweight demo: fresh Cognito pool + gateway with managed ACM cert.
# No OTEL collector, no bundled VPN. Cheapest way to try the auth + inference
# path end-to-end. You supply the network path (any existing corp VPN /
# Direct Connect / TGW that reaches AWS; see infrastructure/network-access/).
#
# Usage:
#   cp config/managed-newcognito-notelemetry.env config/my.env
#   $EDITOR config/my.env
#   source config/my.env && ./deploy-all.sh

# Prereq: a PUBLIC Route53 hosted zone in YOUR OWN AWS account for
# PUBLIC_HOSTED_ZONE_ID below. ACM validates via DNS in that zone.

# --- REQUIRED ---------------------------------------------------------------
export DOMAIN_NAME="claude-gateway.example.com"
export PUBLIC_HOSTED_ZONE_ID="Zxxxxxxxxxxxxx"
export ALLOWED_DOMAINS="example.com"
export COGNITO_ADMIN_EMAIL="admin@example.com"
export COGNITO_DOMAIN_PREFIX="my-org-claude-gw"

# CLIENT_CIDR is the range of your remote clients (your existing VPN pool, or
# whatever network reaches the gateway VPC). ALB ingress on 443 opens to this.
export CLIENT_CIDR="10.0.0.0/8"                           # your client range

# --- Toggles -----------------------------------------------------------------
export IDP_MODE="new-cognito"
export ENABLE_COLLECTOR="false"                           # telemetry off
export ENABLE_VPN="false"                                 # BYO network
export BUILD_IMAGE="true"
