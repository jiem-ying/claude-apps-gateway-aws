# Greenfield: everything bundled — new Cognito pool + bundled OTEL collector +
# bundled Client VPN, all with public ACM certs. One command from clone to demo.
#
# What you need before running:
#   - A PUBLIC Route53 hosted zone in YOUR OWN AWS account (e.g. example.com or
#     a subdomain of a domain you own). ACM validates via DNS and only the zone
#     owner can write the record; you can't borrow someone else's zone.
#   - AWS credentials with permission to create VPC/RDS/ECS/ACM/Route53/ECR etc.
#   - Docker installed (BUILD_IMAGE=true builds the gateway image locally).
#
# Usage:
#   cp config/managed-newcognito-collector-vpn.env config/my.env
#   $EDITOR config/my.env         # fill in the four REQUIRED values below
#   source config/my.env && ./deploy-all.sh

# --- REQUIRED — you must fill these in ---------------------------------------
export DOMAIN_NAME="claude-gateway.example.com"           # under your public zone
export PUBLIC_HOSTED_ZONE_ID="Zxxxxxxxxxxxxx"             # aws route53 list-hosted-zones-by-name
export ALLOWED_DOMAINS="example.com"                      # who may sign in
export COGNITO_ADMIN_EMAIL="admin@example.com"            # temp password mailed here
export COGNITO_DOMAIN_PREFIX="my-org-claude-gw"           # globally unique hosted-UI prefix

# --- Optional overrides (defaults shown) -------------------------------------
# export AWS_REGION="us-east-1"                            # or your AWS CLI default
# export AWS_PROFILE=""                                    # unset = ambient creds
# export CLAUDE_VERSION="2.1.196"                          # gateway binary version

# --- Toggles (locked to this profile's shape) --------------------------------
export IDP_MODE="new-cognito"
export ENABLE_COLLECTOR="true"      # bundled ADOT -> CloudWatch dashboard
export ENABLE_VPN="true"            # bundled AWS Client VPN + .ovpn for the admin
export BUILD_IMAGE="true"           # build the gateway image locally
